PPAI_PROJECT_NAME=ppai-test-umbrella
PPAI_ENV=local
PPAI_BASE_DIR=./runtime_data
PPAI_REQUIREMENTS_DIR=./runtime_data/requirements
PPAI_KNOWLEDGE_DIR=./runtime_data/knowledge
PPAI_GENERATED_DIR=./runtime_data/generated
PPAI_HEALING_MEMORY_DIR=./runtime_data/healing_memory
PPAI_LOG_LEVEL=INFO
--------------------------------------------------------------------------------
PPAI_LLM_PROVIDER=ollama
PPAI_LLM_BASE_URL=http://localhost:11434/v1
PPAI_LLM_API_KEY=ollama
# change this model as per requirement, before running the application, 
# make sure to pull the model using ollama pull command. 
# ollama pull qwen2.5-coder:3b-instruct-q4_0
# PPAI_LLM_MODEL=qwen2.5-coder:3b-instruct-q4_0                   
PPAI_LLM_MODEL=qwen3-coder:480b-cloud
# PPAI_LLM_MODEL=qwen2.5-coder:7b
--------------------------------------------------------------------------------
# For MCP
--------------------------------------------------------------------------------
PPAI_EMBEDDING_MODEL=nomic-embed-text:latest
PPAI_EMBEDDING_BASE_URL=http://localhost:11434
PPAI_EMBEDDING_MODEL=nomic-embed-text:latest